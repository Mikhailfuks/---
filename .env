# Конфигурация сервера
PORT=3000

# Подключение к PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=megafood

# Настройки безопасности (опционально)
JWT_SECRET=your_jwt_secret_key_change_me
NODE_ENV=development

# Настройки бонусов/кэшбэка
DEFAULT_CASHBACK_RATE=5

# Время доставки в минутах по умолчанию
DEFAULT_DELIVERY_TIME=60